{
  "buildCommand": "vite build",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://YOUR_BACKEND_URL/api/:path*" },
    { "source": "/oauth2/:path*", "destination": "https://YOUR_BACKEND_URL/oauth2/:path*" },
    { "source": "/login/:path*", "destination": "https://YOUR_BACKEND_URL/login/:path*" }
  ]
}
